# =============================================================================
# ADOPT API CONFIGURATION
# =============================================================================
# Configuration for connecting to the Adopt AI platform
# These credentials are required to authenticate with the Adopt API

# Client ID for Adopt API authentication
# Get this from your Adopt AI platform dashboard
ADOPT_CLIENT_ID=

# Client secret for Adopt API authentication  
# Get this from your Adopt AI platform dashboard
ADOPT_CLIENT_SECRET=

# Adopt API endpoint URL
# Default: https://connect.adopt.ai
# For on-premise deployments, point this to your Adopt instance URL
ADOPT_API_ENDPOINT=

# =============================================================================
# AWS BEDROCK CONFIGURATION
# =============================================================================
# Configuration for AWS Bedrock Converse integration
# These credentials are required for the LangGraph agent capability checking

# AWS Access Key ID for Bedrock authentication
# Get this from your AWS IAM console
AWS_ACCESS_KEY_ID=

# AWS Secret Access Key for Bedrock authentication
# Get this from your AWS IAM console
AWS_SECRET_ACCESS_KEY=

# AWS Region where Bedrock is available
# Default: us-east-1
AWS_REGION=us-east-1

# Bedrock Converse model to use for capability checking
# Default: anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MODEL=anthropic.claude-3-sonnet-20240229-v1:0

# =============================================================================
# MAXIM EVALUATION CONFIGURATION
# =============================================================================
# Configuration for Maxim evaluation platform
# These credentials are required for bulk evaluation functionality

# Maxim API Key for evaluation platform
# Get this from your Maxim dashboard
MAXIM_API_KEY=

# Maxim Workspace ID for storing evaluation results
# Get this from your Maxim workspace settings
MAXIM_WORKSPACE_ID=
